# Copy this file to .env and fill in your keys.

# Required: OpenAI API key for the LLMs.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required: US Census Bureau API key (free, instant).
# Sign up at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=...

# Optional: LangSmith tracing. Extremely helpful for debugging the router.
# Sign up at https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=...
# LANGSMITH_PROJECT=home-buyer-assistant

# Optional: set to 1 to see extra tracing output in the CLI.
# DEBUG=0
